/* fitting.wxss */

.page-root { height: 100vh; background: var(--color-bg-subtle); display: flex; flex-direction: column; overflow: hidden; }
.main-scroll { flex: 1; overflow: hidden; }

/* ── section ── */
.section {
  background: var(--color-card);
  margin-top: 16rpx;
  padding: 24rpx 28rpx;
  border-top: 1rpx solid var(--color-border);
  border-bottom: 1rpx solid var(--color-border);
}
.section-header { display: flex; flex-direction: row; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.section-title { font-size: 26rpx; font-weight: 700; color: var(--color-muted-fg); letter-spacing: 1rpx; }
.section-sub-header { margin-bottom: 16rpx; }
.section-subtitle { font-size: 26rpx; font-weight: 600; color: var(--color-fg); }
.header-actions { display: flex; flex-direction: row; align-items: center; gap: 12rpx; }

/* ── 形象照 ── */
.type-toggle {
  background: var(--color-muted); border-radius: 999rpx;
  padding: 6rpx 20rpx; font-size: 22rpx; color: var(--color-muted-fg);
}
.type-text { font-size: 22rpx; }
.upload-btn {
  background: var(--color-primary); border-radius: 999rpx;
  padding: 8rpx 24rpx; font-size: 24rpx; color: var(--color-primary-fg); font-weight: 600;
}
.photos-empty { padding: 20rpx 0; }
.photos-empty-text { font-size: 26rpx; color: var(--color-muted-fg); }
.photos-scroll { white-space: nowrap; }
.photos-row { display: flex; flex-direction: row; gap: 16rpx; padding: 4rpx 0 8rpx; }
.photo-card {
  flex-shrink: 0; width: 180rpx; height: 240rpx; border-radius: var(--radius-lg); overflow: hidden;
  border: 2rpx solid var(--color-border); position: relative;
}
.photo-selected { border-color: var(--color-primary); box-shadow: 0 0 0 2rpx var(--color-primary); }
.photo-img { width: 100%; height: 100%; }
.photo-label-wrap { position: absolute; bottom: 0; left: 0; right: 0; background: rgba(0,0,0,.45); padding: 4rpx 8rpx; }
.photo-label { font-size: 20rpx; color: #fff; }
.photo-del { position: absolute; top: 6rpx; right: 6rpx; width: 40rpx; height: 40rpx; background: rgba(0,0,0,.5); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: #fff; line-height: 1; }
.photo-check { position: absolute; top: 6rpx; left: 6rpx; width: 40rpx; height: 40rpx; background: var(--color-primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24rpx; color: var(--color-primary-fg); }

/* ── 模式 tabs ── */
.mode-tabs { display: flex; flex-direction: row; background: var(--color-card); border-top: 1rpx solid var(--color-border); border-bottom: 1rpx solid var(--color-border); margin-top: 16rpx; }
.mode-tab { flex: 1; padding: 20rpx; text-align: center; font-size: 28rpx; color: var(--color-muted-fg); border-bottom: 4rpx solid transparent; }
.mode-tab-active { color: var(--color-primary); border-bottom-color: var(--color-primary); font-weight: 700; }

/* ── 表单 ── */
.form-row { display: flex; flex-direction: row; align-items: center; gap: 16rpx; margin-bottom: 20rpx; }
.form-row-wrap { flex-wrap: wrap; align-items: flex-start; }
.form-label { font-size: 26rpx; color: var(--color-muted-fg); width: 56rpx; flex-shrink: 0; }
.picker-val { display: flex; flex-direction: row; align-items: center; justify-content: space-between; flex: 1; background: var(--color-bg-subtle); border: 1rpx solid var(--color-border); border-radius: var(--radius); padding: 0 20rpx; height: 72rpx; font-size: 28rpx; color: var(--color-fg); }
.picker-arrow { font-size: 32rpx; color: var(--color-muted-fg); }
.input-wrap { flex: 1; background: var(--color-bg-subtle); border: 1rpx solid var(--color-border); border-radius: var(--radius); padding: 0 20rpx; height: 72rpx; display: flex; align-items: center; }
.form-input { width: 100%; font-size: 28rpx; color: var(--color-fg); background: transparent; }
.form-placeholder { color: var(--color-muted-fg); font-size: 26rpx; }
.chips { display: flex; flex-direction: row; flex-wrap: wrap; gap: 12rpx; flex: 1; }
.chip { padding: 10rpx 24rpx; border-radius: 999rpx; border: 1rpx solid var(--color-border); background: var(--color-bg-subtle); font-size: 26rpx; color: var(--color-muted-fg); }
.chip-active { background: var(--color-primary); border-color: var(--color-primary); color: var(--color-primary-fg); }

/* ── 按钮 ── */
.btn-row { margin-top: 8rpx; }
.btn-primary { background: var(--color-primary); border-radius: 999rpx; padding: 18rpx 40rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: var(--color-primary-fg); font-weight: 600; }
.btn-secondary { background: var(--color-bg-subtle); border: 1rpx solid var(--color-border); border-radius: 999rpx; padding: 16rpx 32rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: var(--color-fg); font-weight: 600; }
.btn-generate { width: 100%; box-sizing: border-box; }
.btn-disabled { opacity: .5; }
.rec-error { font-size: 24rpx; color: var(--color-destructive); display: block; margin-top: 12rpx; }

/* ── 推荐结果 ── */
.recommendation-box { margin-top: 20rpx; padding: 20rpx; background: var(--color-bg-subtle); border-radius: var(--radius-lg); border: 1rpx solid var(--color-border); }
.rec-name { font-size: 30rpx; font-weight: 700; color: var(--color-fg); display: block; margin-bottom: 8rpx; }
.rec-reason { font-size: 24rpx; color: var(--color-muted-fg); display: block; line-height: 1.5; margin-bottom: 12rpx; }
.style-tip { background: var(--color-card); border-radius: var(--radius); padding: 12rpx 16rpx; font-size: 23rpx; color: var(--color-muted-fg); margin-bottom: 12rpx; }
.rec-items-row { display: flex; flex-direction: row; flex-wrap: wrap; gap: 12rpx; }
.rec-item-thumb { width: 100rpx; }
.rec-item-img { width: 100rpx; height: 120rpx; border-radius: var(--radius); border: 1rpx solid var(--color-border); }
.rec-item-empty { width: 100rpx; height: 120rpx; border-radius: var(--radius); background: var(--color-muted); display: flex; align-items: center; justify-content: center; font-size: 40rpx; }
.rec-item-name { font-size: 20rpx; color: var(--color-muted-fg); display: block; text-align: center; margin-top: 4rpx; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }

/* ── 手动选衣网格 ── */
.items-grid { display: flex; flex-direction: row; flex-wrap: wrap; gap: 14rpx; }
.item-thumb { width: calc(33.333% - 10rpx); position: relative; border: 2rpx solid var(--color-border); border-radius: var(--radius); overflow: hidden; background: var(--color-bg-subtle); }
.item-thumb-selected { border-color: var(--color-primary); }
.item-thumb-img { width: 100%; height: 160rpx; }
.item-thumb-empty { width: 100%; height: 160rpx; display: flex; align-items: center; justify-content: center; font-size: 48rpx; background: var(--color-muted); }
.item-thumb-name { font-size: 20rpx; color: var(--color-fg); display: block; padding: 6rpx 8rpx; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.item-check { position: absolute; top: 6rpx; right: 6rpx; width: 36rpx; height: 36rpx; background: var(--color-primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22rpx; color: var(--color-primary-fg); }

/* ── 合成区 ── */
.generate-section { }
.hint-warn { font-size: 24rpx; color: var(--color-destructive); display: block; margin-bottom: 16rpx; }
.hint-text { font-size: 26rpx; color: var(--color-muted-fg); }

/* ── 结果区 ── */
.result-section { }
.generating-hint { display: flex; flex-direction: row; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.generating-text { font-size: 26rpx; color: var(--color-muted-fg); }
.preview-block { margin-bottom: 20rpx; }
.preview-label { font-size: 24rpx; color: var(--color-muted-fg); font-weight: 600; display: block; margin-bottom: 10rpx; }
.preview-img { width: 100%; border-radius: var(--radius-lg); border: 1rpx solid var(--color-border); }
.result-img { }
.tap-hint { font-size: 22rpx; color: var(--color-muted-fg); display: block; margin-top: 8rpx; }
.error-box { background: rgba(220,38,38,.06); border: 1rpx solid rgba(220,38,38,.2); border-radius: var(--radius); padding: 16rpx; }
.error-text { font-size: 26rpx; color: var(--color-destructive); }

/* ── 历史 mini ── */
.more-btn { font-size: 24rpx; color: var(--color-primary); }
.history-mini-list { display: flex; flex-direction: row; gap: 16rpx; }
.history-mini-card { flex: 1; }
.history-mini-img-wrap { width: 100%; height: 180rpx; border-radius: var(--radius); overflow: hidden; background: var(--color-muted); margin-bottom: 8rpx; }
.history-mini-img { width: 100%; height: 100%; }
.history-mini-empty { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 48rpx; }
.history-mini-name { font-size: 22rpx; color: var(--color-muted-fg); display: block; text-align: center; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }

.bottom-gap { height: 40rpx; }
