/* outfits.wxss */

.page-root { height: 100vh; background: var(--color-bg-subtle); display: flex; flex-direction: column; overflow: hidden; }
.main-scroll { flex: 1; overflow: hidden; }

/* ── 卡片区块 ── */
.card-section {
  background: var(--color-card);
  margin: 16rpx 0 0;
  padding: 28rpx;
  border-top: 1rpx solid var(--color-border);
  border-bottom: 1rpx solid var(--color-border);
}
.section-title { font-size: 24rpx; font-weight: 700; color: var(--color-muted-fg); letter-spacing: 1rpx; display: block; margin-bottom: 20rpx; }

/* ── 表单行 ── */
.form-row {
  display: flex; flex-direction: row; align-items: center;
  gap: 16rpx; margin-bottom: 20rpx;
}
.form-row-wrap { flex-wrap: wrap; align-items: flex-start; }
.form-label { font-size: 26rpx; color: var(--color-muted-fg); width: 56rpx; flex-shrink: 0; }
.picker-val {
  display: flex; flex-direction: row; align-items: center; justify-content: space-between;
  flex: 1; background: var(--color-bg-subtle); border: 1rpx solid var(--color-border);
  border-radius: var(--radius); padding: 0 20rpx; height: 72rpx;
  font-size: 28rpx; color: var(--color-fg);
}
.picker-arrow { font-size: 32rpx; color: var(--color-muted-fg); }
.input-wrap {
  flex: 1; background: var(--color-bg-subtle); border: 1rpx solid var(--color-border);
  border-radius: var(--radius); padding: 0 20rpx; height: 72rpx;
  display: flex; align-items: center;
}
.form-input { width: 100%; font-size: 28rpx; color: var(--color-fg); background: transparent; }
.form-placeholder { color: var(--color-muted-fg); font-size: 26rpx; }

/* ── 场合 chips ── */
.occasion-chips { display: flex; flex-direction: row; flex-wrap: wrap; gap: 12rpx; flex: 1; }
.occ-chip {
  padding: 10rpx 24rpx; border-radius: 999rpx;
  border: 1rpx solid var(--color-border);
  background: var(--color-bg-subtle);
  font-size: 26rpx; color: var(--color-muted-fg);
}
.occ-chip-active {
  background: var(--color-primary); border-color: var(--color-primary); color: var(--color-primary-fg);
}

/* ── 生成按钮 ── */
.generate-row { display: flex; flex-direction: row; align-items: center; gap: 20rpx; margin-top: 8rpx; }
.btn-primary {
  background: var(--color-primary); border-radius: 999rpx;
  padding: 18rpx 40rpx; display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: var(--color-primary-fg); font-weight: 600;
}
.btn-generate { flex: 1; }
.btn-outline {
  border: 1rpx solid var(--color-border); border-radius: 999rpx;
  padding: 12rpx 24rpx; display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: var(--color-fg); background: var(--color-card);
}
.btn-sm { padding: 10rpx 24rpx; font-size: 24rpx; }
.btn-disabled { opacity: .5; }
.saved-hint { font-size: 24rpx; color: var(--color-success); }
.rec-error { font-size: 24rpx; color: var(--color-destructive); display: block; margin-top: 12rpx; }

/* ── 推荐结果 ── */
.result-card { }
.result-header { display: flex; flex-direction: row; align-items: flex-start; gap: 16rpx; margin-bottom: 16rpx; }
.result-header-left { flex: 1; }
.result-name { font-size: 34rpx; font-weight: 700; color: var(--color-fg); display: block; margin-bottom: 8rpx; }
.result-reason { font-size: 26rpx; color: var(--color-muted-fg); display: block; line-height: 1.5; }
.style-tip {
  background: var(--color-bg-subtle); border-radius: var(--radius); padding: 16rpx 20rpx;
  font-size: 26rpx; color: var(--color-muted-fg); line-height: 1.5; margin-bottom: 20rpx;
}
.sub-label { font-size: 26rpx; font-weight: 600; color: var(--color-fg); display: block; margin-bottom: 16rpx; }

/* 推荐单品网格 */
.items-grid { display: flex; flex-direction: row; flex-wrap: wrap; gap: 16rpx; }
.item-card {
  width: calc(50% - 8rpx); background: var(--color-bg-subtle);
  border: 1rpx solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden;
}
.item-img-wrap { width: 100%; height: 340rpx; background: var(--color-muted); }
.item-img { width: 100%; height: 340rpx; }
.item-img-empty {
  width: 100%; height: 220rpx; display: flex; align-items: center; justify-content: center;
  font-size: 56rpx;
}
.item-info { padding: 12rpx 16rpx 16rpx; }
.item-name { font-size: 24rpx; font-weight: 600; color: var(--color-fg); display: block; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.item-color { font-size: 20rpx; color: var(--color-muted-fg); display: block; margin-top: 4rpx; }
.no-items-hint { font-size: 26rpx; color: var(--color-muted-fg); display: block; margin-bottom: 16rpx; }

.fitting-row {
  display: flex; flex-direction: row; align-items: center; gap: 16rpx;
  margin-top: 24rpx; padding-top: 20rpx; border-top: 1rpx solid var(--color-border);
}
.fitting-hint { font-size: 26rpx; color: var(--color-muted-fg); }

/* ── 空引导 ── */
.empty-guide {
  margin: 32rpx 28rpx; padding: 60rpx 40rpx;
  border: 2rpx dashed var(--color-border); border-radius: var(--radius-lg);
  display: flex; flex-direction: column; align-items: center; gap: 12rpx;
}
.empty-icon { font-size: 96rpx; }
.empty-title { font-size: 28rpx; font-weight: 600; color: var(--color-fg); }
.empty-desc { font-size: 24rpx; color: var(--color-muted-fg); text-align: center; line-height: 1.6; }

/* ── 历史记录 ── */
.history-list { display: flex; flex-direction: row; flex-wrap: wrap; gap: 16rpx; }
.history-card {
  width: calc(50% - 8rpx); background: var(--color-bg-subtle);
  border: 1rpx solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden;
}
.history-img-wrap { width: 100%; height: 200rpx; background: var(--color-muted); }
.history-img { width: 100%; height: 100%; }
.history-img-empty {
  width: 100%; height: 200rpx; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 8rpx;
}
.history-status-icon { font-size: 48rpx; }
.history-status-text { font-size: 20rpx; color: var(--color-muted-fg); }

.thumb-row { display: flex; flex-direction: row; flex-wrap: wrap; gap: 6rpx; padding: 8rpx 10rpx 0; }
.thumb-item { width: 48rpx; height: 48rpx; border-radius: 8rpx; overflow: hidden; background: var(--color-muted); }
.thumb-img { width: 100%; height: 100%; }
.thumb-empty { width: 100%; height: 100%; background: var(--color-muted); }
.thumb-extra {
  width: 48rpx; height: 48rpx; border-radius: 8rpx; background: var(--color-muted);
  display: flex; align-items: center; justify-content: center;
  font-size: 18rpx; color: var(--color-muted-fg);
}

.history-info { padding: 10rpx 12rpx 14rpx; }
.history-name { font-size: 24rpx; font-weight: 600; color: var(--color-fg); display: block; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.history-meta { display: flex; flex-direction: row; align-items: center; gap: 8rpx; margin: 6rpx 0; flex-wrap: wrap; }
.meta-tag { font-size: 20rpx; background: var(--color-muted); border-radius: 999rpx; padding: 2rpx 12rpx; color: var(--color-muted-fg); }
.meta-date { font-size: 20rpx; color: var(--color-muted-fg); }
.history-reason { font-size: 20rpx; color: var(--color-muted-fg); display: block; line-height: 1.4; overflow: hidden; max-height: 56rpx; }

.bottom-gap { height: 40rpx; }
