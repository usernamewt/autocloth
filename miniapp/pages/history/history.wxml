<!-- history.wxml -->
<page-meta page-style="{{pageStyle}}" />
<view class="page-root">

  <!-- loading -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <text class="loading-text">加载中…</text>
  </view>

  <!-- empty -->
  <view wx:elif="{{!history.length}}" class="empty-wrap">
    <text class="empty-icon">👗</text>
    <text class="empty-title">暂无试衣记录</text>
    <text class="empty-desc">去试衣间生成你的第一套穿搭效果</text>
    <view class="btn-primary" bindtap="goFitting">
      <text>前往试衣间</text>
    </view>
  </view>

  <!-- list -->
  <scroll-view wx:else class="main-scroll safe-area-bottom" scroll-y>
    <!-- 今日穿搭 banner -->
    <view wx:if="{{todayBanner}}" class="today-banner">
      <text class="today-banner-icon">{{todayBanner.status === 'ready' ? '✨' : '⏳'}}</text>
      <view class="today-banner-texts">
        <text class="today-banner-title">穿搭闹钟 · 今日已备好</text>
        <text class="today-banner-name">{{todayBanner.outfit_name}}</text>
      </view>
    </view>
    <view class="list">
      <view wx:for="{{history}}" wx:for-item="r" wx:key="id" class="card">

        <!-- 图片区 -->
        <view class="card-img-wrap" bindtap="onViewImage" data-url="{{r.result_image_url}}">
          <image wx:if="{{r.hasImage}}" class="card-img" src="{{r.result_image_url}}" mode="aspectFill" />
          <view wx:elif="{{r.isPureRec}}" class="card-img-empty pure-rec">
            <text class="card-img-icon">👗</text>
            <text class="card-img-label">穿搭推荐</text>
          </view>
          <view wx:else class="card-img-empty">
            <text class="card-img-icon">{{r.statusIcon}}</text>
            <text class="card-img-label">{{r.statusLabel}}</text>
          </view>
        </view>

        <!-- 衣物缩略图行 -->
        <view wx:if="{{r.thumbs.length}}" class="thumb-row">
          <view wx:for="{{r.thumbs}}" wx:for-item="th" wx:key="id" class="thumb-item">
            <image wx:if="{{th.imgUrl}}" class="thumb-img" src="{{th.imgUrl}}" mode="aspectFill" />
            <view wx:else class="thumb-empty"></view>
          </view>
          <view wx:if="{{r.extraCount > 0}}" class="thumb-extra">
            <text>+{{r.extraCount}}</text>
          </view>
        </view>

        <!-- 文字信息 -->
        <view class="card-body">
          <text wx:if="{{r.outfit_name}}" class="card-name">{{r.outfit_name}}</text>

          <view class="card-meta">
            <text wx:if="{{r.occasion}}" class="meta-tag">{{r.occasion}}</text>
            <text wx:if="{{r.outfit_date}}" class="meta-date">{{r.outfit_date}}</text>
          </view>

          <text wx:if="{{r.reasoning}}" class="card-reason">{{r.reasoning}}</text>
          <text wx:if="{{r.style_tips}}" class="card-tips">💡 {{r.style_tips}}</text>

          <view class="card-footer">
            <text class="card-time">{{r.fmtTime}}</text>
            <view class="del-btn" catchtap="onDeleteResult" data-id="{{r.id}}">
              <text>删除</text>
            </view>
          </view>
        </view>

      </view>
    </view>
    <view class="bottom-gap"></view>
  </scroll-view>

</view>
